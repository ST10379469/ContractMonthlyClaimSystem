@using ContractMonthlyClaimSystem.Models
@model List<MonthlyClaim>
@{
    ViewData["Title"] = "My Claims";
}

<h2>My Claims</h2>

<div class="table-responsive">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Month/Year</th>
                <th>Total Amount</th>
                <th>Status</th>
                <th>Submitted Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var claim in Model)
            {
                <tr>
                    <td>@claim.Month/@claim.Year</td>
                    <td>@claim.TotalAmount.ToString("C")</td>
                    <td>
                        <span class="badge bg-@(claim.Status == ClaimStatus.Approved ? "success" : 
                                              claim.Status == ClaimStatus.Rejected ? "danger" : 
                                              claim.Status == ClaimStatus.PendingReview ? "warning" : "secondary")">
                            @claim.Status
                        </span>
                    </td>
                    <td>@claim.SubmittedDate?.ToString("d")</td>
                </tr>
            }
        </tbody>
    </table>
</div>